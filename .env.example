# ─────────────────────────────────────────────────────────────
# KG-RAG-Project — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — only commit this .env.example file.
# ─────────────────────────────────────────────────────────────

# Neo4j AuraDB Free Tier credentials
# Get these from: https://console.neo4j.io
# → Create a Free instance → download the credentials file
# Note: On AuraDB, NEO4J_USERNAME and NEO4J_DATABASE are typically
#       the same value (the instance ID, e.g. "d349a659")
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=xxxxxxxx
NEO4J_PASSWORD=your-auradb-password-here
NEO4J_DATABASE=xxxxxxxx

# Anthropic API key — used for all LLM calls (Claude Haiku)
# Get from: https://console.anthropic.com → API Keys
# Cost: ~$0.004–$0.005 per question (3 patterns run per question)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
